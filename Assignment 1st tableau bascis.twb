  <dashboards>
    <dashboard enable-sort-zone-taborder='true' name='Q.1'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='3' type-v2='text' w='98400' x='800' y='1000'>
            <formatted-text>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Æ                                                         </run>
              <run fontcolor='#000000' fontname='Benton Sans Book' underline='true'>  Tableau Basics</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book' underline='true'>Assignment:-</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Q1. Explain what Tableau is and why it is preferred over traditional spreadsheet tools for data analysis. Also mention any two industries where Tableau is commonly used and explain one use case.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Answer:-</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Tableau</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'> is a data visualization and business intelligence tool used to analyze data and create interactive dashboards, charts, and reports. It helps convert raw data into meaningful and easy-to-understand insights.</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Why Tableau is preferred over traditional spreadsheet tools (like Excel):</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Provides </run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>interactive and advanced visualizations</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Can handle </run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>large datasets efficiently</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Easy to use with </run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>drag-and-drop interface</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Supports </run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>real-time data analysis</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Faster and more effective for </run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>data-driven decision making</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Industries where Tableau is commonly used:</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Healthcare </run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Retail </run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Use Case (Retail Industry):</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>In the </run>
              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>retail industry</run>
              <run fontcolor='#000000' fontname='Benton Sans Book'>, Tableau is used to analyze sales data.
For example, a company can track product sales, identify best-selling items, analyze customer behavior, and monitor profits. This helps in making better business decisions and improving overall performance.</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
